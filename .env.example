# Copie para .env e ajuste conforme necessário
# cp .env.example .env

CENTRAL_URL=http://127.0.0.1:8000
CAMERA_ID=0
CAMERA_LABEL=cam-01
SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=5.0
DETECTION_INTERVAL_SECONDS=0.5
DISPLAY_FPS=30
PREVIEW_WIDTH=640
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
ALERT_COOLDOWN_SECONDS=15.0

# Anti falso positivo
DETECTION_CONFIRMATIONS_REQUIRED=2
MIN_ALERT_CONFIDENCE=0.55
SCREAM_ENERGY_THRESHOLD=0.025
SCREAM_HIGH_BAND_RATIO=1.35
IMPACT_ENERGY_THRESHOLD=0.018
IMPACT_PEAK_RATIO=5.0

# Evidência: vídeo (5 s) em vez de foto por padrão
ALERT_SAVE_VIDEO=true
ALERT_VIDEO_SECONDS=5.0
VIDEO_BUFFER_SECONDS=6.0
ALERT_SAVE_SNAPSHOT=false

TRANSCRIPTION_ENABLED=true
VOSK_MODEL_PATH=data/models/vosk-model-small-pt-0.3
HELP_KEYWORDS=socorro,me ajuda,me ajudem,preciso de ajuda,alguém me ajuda,chama a polícia,polícia
HELP_MIN_CONFIDENCE=0.85
HELP_MIN_WORD_CONFIDENCE=0.45
HELP_CONFIRMATIONS_REQUIRED=2

# Machine learning
ML_ENABLED=true
ML_CONFIDENCE_THRESHOLD=0.65
ML_HEURISTIC_FALLBACK=true
